{% set footerLinks = navLinksFooter|default({'int': [], 'ext': []}) %}

<footer id="site-footer" class="border-t border-dark-soft bg-dark text-fg-light mt-12">
	<div class="mx-auto max-w-7xl {{ layout_horizontal_class|default('lg:px-20 md:px-10 px-2') }} py-12">
		<div class="flex flex-col gap-12 md:gap-0 md:flex-row md:items-center md:justify-between">
			<div class="flex min-h-full flex-col justify-center text-center">
				<h4 class="text-lg font-semibold font-body uppercase tracking-wide text-fg-light">
					Adresse
				</h4>
				<div class="mt-4 space-y-2 text-sm leading-6 text-fg-light/90">
					<p>39 Rue du Breteil, 33320 Eysines</p>
					<p>TEL +33 05 56 16 18 80</p>
				</div>
			</div>

			<div class="flex min-h-full flex-col items-center justify-center text-center">
				<a href="/" class="inline-flex items-center justify-center">
					<img src="{{ base_url('images/Logo.png') }}" class="h-12 w-auto" alt="Korus Imprimerie">
				</a>

				<div class="mt-6 w-full flex items-center justify-around gap-3 px-2">

					<a href="#" target="_blank" rel="noopener noreferrer" class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-white bg-white text-dark-soft transition-colors duration-200 hover:border-dark-soft hover:bg-dark-soft hover:text-fg-light focus:outline-none focus:ring-4 focus:ring-fg-light/20" aria-label="Réseau social 1">
						<svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewbox="0 0 24 24">
							<path fill-rule="evenodd" d="M21.7 8.037a4.26 4.26 0 0 0-.789-1.964 2.84 2.84 0 0 0-1.984-.839c-2.767-.2-6.926-.2-6.926-.2s-4.157 0-6.928.2a2.836 2.836 0 0 0-1.983.839 4.225 4.225 0 0 0-.79 1.965 30.146 30.146 0 0 0-.2 3.206v1.5a30.12 30.12 0 0 0 .2 3.206c.094.712.364 1.39.784 1.972.604.536 1.38.837 2.187.848 1.583.151 6.731.2 6.731.2s4.161 0 6.928-.2a2.844 2.844 0 0 0 1.985-.84 4.27 4.27 0 0 0 .787-1.965 30.12 30.12 0 0 0 .2-3.206v-1.516a30.672 30.672 0 0 0-.202-3.206Zm-11.692 6.554v-5.62l5.4 2.819-5.4 2.801Z" clip-rule="evenodd"/>
						</svg>
						<span class="sr-only">Réseau social Youtube</span>
					</a>

					<a href="#" target="_blank" rel="noopener noreferrer" class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-white bg-white text-dark-soft transition-colors duration-200 hover:border-dark-soft hover:bg-dark-soft hover:text-fg-light focus:outline-none focus:ring-4 focus:ring-fg-light/20" aria-label="Réseau social 2">
						<svg class="h-5 w-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewbox="0 0 24 24">
							<path fill-rule="evenodd" d="M3 8a5 5 0 0 1 5-5h8a5 5 0 0 1 5 5v8a5 5 0 0 1-5 5H8a5 5 0 0 1-5-5V8Zm5-3a3 3 0 0 0-3 3v8a3 3 0 0 0 3 3h8a3 3 0 0 0 3-3V8a3 3 0 0 0-3-3H8Zm7.597 2.214a1 1 0 0 1 1-1h.01a1 1 0 1 1 0 2h-.01a1 1 0 0 1-1-1ZM12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm-5 3a5 5 0 1 1 10 0 5 5 0 0 1-10 0Z" clip-rule="evenodd"/>
						</svg>
						<span class="sr-only">Réseau social Instagram</span>
					</a>

					<a href="#" target="_blank" rel="noopener noreferrer" class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-white bg-white text-dark-soft transition-colors duration-200 hover:border-dark-soft hover:bg-dark-soft hover:text-fg-light focus:outline-none focus:ring-4 focus:ring-fg-light/20" aria-label="Réseau social 3">
						<svg class="h-5 w-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewbox="0 0 24 24">
							<path fill-rule="evenodd" d="M12.51 8.796v1.697a3.738 3.738 0 0 1 3.288-1.684c3.455 0 4.202 2.16 4.202 4.97V19.5h-3.2v-5.072c0-1.21-.244-2.766-2.128-2.766-1.827 0-2.139 1.317-2.139 2.676V19.5h-3.19V8.796h3.168ZM7.2 6.106a1.61 1.61 0 0 1-.988 1.483 1.595 1.595 0 0 1-1.743-.348A1.607 1.607 0 0 1 5.6 4.5a1.601 1.601 0 0 1 1.6 1.606Z" clip-rule="evenodd"/>
							<path d="M7.2 8.809H4V19.5h3.2V8.809Z"/>
						</svg>
						<span class="sr-only">Réseau social Linkedin</span>
					</a>
				</div>
			</div>


			<div class="flex min-h-full flex-col justify-center text-center">
				<h4 class="text-lg font-semibold font-body uppercase tracking-wide text-fg-light">
					Nos sites
				</h4>
				<ul class="mt-4 space-y-2 text-sm leading-6 text-fg-light/90">
					{% for item in footerLinks.ext|default([]) %}
						<li>
							<a href="{{ item.href }}" target="{{ item.target|default('_blank') }}" rel="{{ item.rel|default('noopener noreferrer') }}" class="transition-colors duration-200 hover:text-fg-light">
								{{ item.label }}
							</a>
						</li>
					{% endfor %}
				</ul>
			</div>
		</div>
	</div>
</footer>
