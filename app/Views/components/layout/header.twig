{% set headerLinks = navLinksHeader|default([]) %}
{% set ctaLink = headerLinks|length > 0 ? headerLinks|last : {'label': 'Contact / devis', 'href': '/contact-devis'} %}
{% set navLinks = headerLinks|length > 0 ? headerLinks|slice(0, headerLinks|length - 1) : [] %}

<header id="site-header" class="fixed inset-x-0 top-0 z-50 border-b border-dark-soft bg-dark text-fg-light">
	<nav>
		<div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between md:justify-center md:gap-12 px-4 py-4">
			<a href="/" class="flex items-center gap-3">
				<img src="/images/Logo.png" class="h-10 w-auto shrink-0" alt="Korus Imprimerie">
				<span class="sr-only">Korus Imprimerie</span>
			</a>
			<div class="flex items-center gap-2 md:order-2">
				<a href="{{ ctaLink.href }}" class="inline-flex items-center justify-center rounded-none border border-brand-strong px-3 py-2 text-sm font-medium text-fg-light transition-colors duration-200 hover:border-brand hover:text-fg-brand focus:outline-none focus:ring-2 focus:ring-brand-strong/40">
					{{ ctaLink.label }}
				</a>
			</div>
			<button data-collapse-toggle="site-navigation" type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-base border border-brand-strong/60 bg-dark-soft text-fg-light transition-colors duration-200 md:hidden hover:border-brand hover:bg-brand-soft hover:text-heading focus:outline-none focus:ring-2 focus:ring-brand-strong/40" aria-controls="navbar-default" aria-expanded="false">
				<span class="sr-only">Open main menu</span>
				<svg class="w-6 h-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewbox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-width="2" d="M5 7h14M5 12h14M5 17h14"/></svg>
			</button>
			<div class="hidden w-full md:order-1 md:flex md:w-auto" id="site-navigation">
				<ul class="mt-4 flex flex-col gap-1 border border-dark-soft bg-dark-soft p-3 text-sm font-medium md:mt-0 md:flex-row md:flex-wrap md:items-center md:gap-x-6 md:gap-y-2 md:border-0 md:bg-transparent md:p-0">
					{% for item in navLinks %}
						<li class="md:flex md:items-center">
							<a href="{{ item.href }}" class="block px-3 py-2 text-fg-light transition-colors duration-200 hover:text-fg-brand md:px-0 md:py-0">
								{{ item.label }}
							</a>
						</li>
					{% endfor %}
				</ul>
			</div>
		</div>
	</nav>
</header>
