{% set layout_horizontal_class = 'lg:px-40 md:px-20 px-3' %}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{% block meta_description %}{{ meta_description|default('Korus Imprimerie, imprimerie traditionnelle à Bordeaux.') }}{% endblock %}">
    <title>{% block title %}{{ title|default('Korus Imprimerie') }}{% endblock %}</title>
    <link rel="icon" href="/favicon.ico">
    <link rel="stylesheet" href="{{ base_url('css/styles.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body class="{% block body_class %}bg-korus-bg font-body text-body antialiased{% endblock %}">
    {% block header %}{% endblock %}

    <main id="main-content" class="{% block main_class %}min-h-screen{% endblock %} {{ layout_horizontal_class|default('lg:px-20 md:px-10 px-2') }}">
        {% block content %}{% endblock %}
    </main>

    {{ include('components/layout/footer.twig') }}

    {% block javascripts %}
        <script src="{{ base_url('js/flowbite.min.js') }}" defer></script>
    {% endblock %}
</body>
</html>
